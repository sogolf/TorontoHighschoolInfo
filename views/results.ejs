<%- include('header', { title: 'Your Results', currentPage: 'quiz' }) %>

<!-- Results hero -->
<section class="results-hero">
  <div class="container">
    <p style="color:rgba(255,255,255,.75);font-size:1rem;margin-bottom:.5rem">Your school option recommendation</p>
    <h1>Your Best-Fit Option</h1>
    <div class="pathway-badge-lg">
      <span style="font-size:2rem"><%= topPathway.emoji %></span>
      <span><%= topPathway.label %></span>
    </div>
    <p style="color:rgba(255,255,255,.85);max-width:560px;margin:0 auto"><%= topPathway.description %></p>
  </div>
</section>

<!-- Score breakdown -->
<section class="section-sm" style="background:var(--gray-100)">
  <div class="container">
    <h2 class="mb-2">Score Breakdown</h2>
    <p style="color:var(--gray-500);margin-bottom:1.5rem">Based on your 12 answers, here's how you scored across all four high school options.</p>
    <div class="confidence-bars">
      <% breakdown.forEach(function(b) { %>
      <div class="bar-row">
        <div class="bar-label"><%= b.emoji %> <%= b.label %></div>
        <div class="bar-track">
          <div class="bar-fill bar-<%= b.id %>" style="width:<%= b.pct %>%"><%= b.pct %>%</div>
        </div>
      </div>
      <% }) %>
    </div>
    <p class="mt-2" style="font-size:.85rem;color:var(--gray-500)">Remember: this is a starting point for reflection, not a final decision. All options can lead to a great high school experience.</p>
  </div>
</section>

<!-- Also consider -->
<% if (also && also.length > 0) { %>
<section class="section-sm">
  <div class="container">
    <h2 class="mb-2">Also Consider</h2>
    <div class="grid-3">
      <% also.forEach(function(a) { %>
      <div class="card">
        <div class="card-icon"><%= a.emoji %></div>
        <div class="card-title"><%= a.label %></div>
        <div class="card-desc"><%= a.description ? a.description.substring(0, 120) : '' %>…</div>
        <div class="mt-2" style="font-size:.85rem;color:var(--gray-500)">Score: <%= a.pct %>%</div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- What this means for your application -->
<section class="section-sm" style="background:var(--teal-50)">
  <div class="container">
    <h2 class="mb-2">What This Means for Your Application</h2>
    <div class="grid-2">
      <div>
        <h3 class="mb-1">Application process</h3>
        <p style="color:var(--gray-700)"><%= topPathway.applicationProcess %></p>

        <h3 class="mb-1 mt-2">Who this is for</h3>
        <p style="color:var(--gray-700)"><%= topPathway.whoItsFor %></p>

        <div class="info-box info-box-amber mt-2">
          <strong>Admission:</strong> <%= topPathway.admissionAvg %>
        </div>
      </div>
      <div>
        <h3 class="mb-1">What you'll get</h3>
        <ul>
          <% topPathway.keyFeatures.forEach(function(f) { %>
          <li><%= f %></li>
          <% }) %>
        </ul>

        <h3 class="mb-1 mt-2">Pros of this option</h3>
        <div class="pill-list">
          <% topPathway.pros.slice(0,3).forEach(function(pro) { %>
          <span class="pill pill-green"><%= pro %></span>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTAs -->
<section class="section-sm">
  <div class="container text-center">
    <h2 class="mb-2">What's Next?</h2>
    <div class="flex-center" style="flex-wrap:wrap">
      <a href="/explore#<%= topPathway.id %>" class="btn btn-primary">🗺️ Explore <%= topPathway.label %></a>
      <a href="/planner" class="btn btn-secondary">📋 Open Application Planner</a>
      <a href="/quiz" class="btn btn-outline">🔄 Retake the Quiz</a>
    </div>
    <p class="mt-2" style="color:var(--gray-500);font-size:.9rem">Talk to your Grade 8 teacher and guidance counselor to discuss your options — they know you best.</p>
  </div>
</section>

<%- include('footer') %>
